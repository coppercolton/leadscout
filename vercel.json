// ---------- button ----------
const Btn = ({ children, variant = 'primary', size = 'md', ...rest }) => {
  const sizes = {
    sm: { padding: '6px 12px', fontSize: 12, height: 28 },
    md: { padding: '10px 16px', fontSize: 13, height: 38 },
    lg: { padding: '14px 22px', fontSize: 14, height: 48 },
  };
  const variants = {
    primary: { background: 'var(--fg)', color: 'var(--bg)', border: '1px solid var(--fg)' },
    secondary: { background: 'transparent', color: 'var(--fg)', border: '1px solid var(--border-strong)' },
    ghost: { background: 'transparent', color: 'var(--fg-muted)', border: '1px solid transparent' },
    accent: { background: 'var(--accent)', color: 'oklch(0.14 0.006 60)', border: '1px solid var(--accent)' },
    outline: { background: 'transparent', color: 'var(--accent-text)', border: '1px solid var(--accent-line)' },
  };
  return (
    <button
      style={{
        ...sizes[size], ...variants[variant],
        display: 'inline-flex', alignItems: 'center', gap: 8,
        borderRadius: 999, fontWeight: 500, letterSpacing: '-0.005em',
        cursor: 'pointer', transition: 'all 0.15s ease',
        fontFamily: 'var(--font-sans)', whiteSpace: 'nowrap',
      }}
      {...rest}
    >
      {children}
    </button>
  );
};

// ---------- card / hairline surfaces ----------
const Card = ({ children, pad = 20, style, ...rest }) => (
  <div style={{
    background: 'var(--bg-elev)',
    border: '1px solid var(--border)',
    borderRadius: 14,
    padding: pad,
    ...style,
  }} {...rest}>{children}</div>
);

const Hairline = ({ vertical, style }) => (
  <div style={{
    background: 'var(--hairline)',
    [vertical ? 'width' : 'height']: 1,
    [vertical ? 'height' : 'width']: '100%',
    ...style,
  }} />
);

// ---------- meta label (mono caps) ----------
const Meta = ({ children, style, color }) => (
  <span style={{
    fontFamily: 'var(--font-mono)',
    fontSize: 10,
    letterSpacing: '0.12em',
    textTransform: 'uppercase',
    color: color || 'var(--fg-subtle)',
    ...style,
  }}>{children}</span>
);

// ---------- badge / pill ----------
const Pill = ({ children, tone = 'neutral', style, dot }) => {
  const tones = {
    neutral: { bg: 'var(--hairline)', fg: 'var(--fg-muted)', dotC: 'var(--fg-subtle)' },
    accent:  { bg: 'var(--accent-soft)', fg: 'var(--accent-text)', dotC: 'var(--accent)' },
    good:    { bg: 'oklch(0.75 0.14 150 / 0.14)', fg: 'oklch(0.82 0.14 150)', dotC: 'oklch(0.75 0.14 150)' },
    warn:    { bg: 'oklch(0.82 0.14 85 / 0.14)', fg: 'oklch(0.88 0.14 85)', dotC: 'oklch(0.82 0.14 85)' },
    bad:     { bg: 'oklch(0.68 0.2 25 / 0.14)', fg: 'oklch(0.76 0.18 25)', dotC: 'oklch(0.68 0.2 25)' },
  };
  const t = tones[tone];
  return (
    <span style={{
      display: 'inline-flex', alignItems: 'center', gap: 6,
      background: t.bg, color: t.fg,
      padding: '3px 9px', borderRadius: 999,
      fontFamily: 'var(--font-sans)', fontSize: 11, fontWeight: 500,
      letterSpacing: '-0.005em',
      ...style,
    }}>
      {dot && <span style={{ width: 6, height: 6, borderRadius: '50%', background: t.dotC }} />}
      {children}
    </span>
  );
};

// ---------- avatar (initials on tinted bg) ----------
const Avatar = ({ name = '??', size = 32, hue }) => {
  const initials = name.split(' ').map(n => n[0]).slice(0, 2).join('').toUpperCase();
  // stable hue from name
  const h = hue ?? ([...name].reduce((a, c) => a + c.charCodeAt(0), 0) * 37) % 360;
  return (
    <div style={{
      width: size, height: size, borderRadius: '50%',
      background: `oklch(0.68 0.12 ${h} / 0.25)`,
      color: `oklch(0.85 0.1 ${h})`,
      display: 'flex', alignItems: 'center', justifyContent: 'center',
      fontFamily: 'var(--font-sans)', fontSize: size * 0.38, fontWeight: 600,
      letterSpacing: '-0.02em',
      border: `1px solid oklch(0.68 0.12 ${h} / 0.2)`,
      flexShrink: 0,
    }}>{initials}</div>
  );
};

// ---------- image placeholder (striped, per guidance) ----------
const Placeholder = ({ w = '100%', h = 200, label = 'image', style }) => (
  <div style={{
    width: w, height: h, position: 'relative', overflow: 'hidden',
    background: `repeating-linear-gradient(135deg, var(--hairline) 0 8px, transparent 8px 16px)`,
    border: '1px solid var(--border)', borderRadius: 10,
    display: 'flex', alignItems: 'center', justifyContent: 'center',
    ...style,
  }}>
    <span style={{
      fontFamily: 'var(--font-mono)', fontSize: 10, color: 'var(--fg-subtle)',
      letterSpacing: '0.1em', textTransform: 'uppercase',
      background: 'var(--bg)', padding: '4px 8px', borderRadius: 4,
      border: '1px solid var(--border)',
    }}>{label}</span>
  </div>
);

// ---------- concentric rings motif (decorative; simple circles only) ----------
const Rings = ({ size = 320, color, style }) => {
  const c = color || 'var(--accent)';
  const half = size / 2;
  return (
    <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} style={style} aria-hidden>
      {[1, 2, 3, 4, 5, 6, 7].map(i => (
        <circle key={i} cx={half} cy={half} r={i * (half / 8)}
                fill="none" stroke={c} strokeWidth="0.5" opacity={0.08 + i * 0.04} />
      ))}
      <circle cx={half} cy={half} r="3" fill={c} />
    </svg>
  );
};

Object.assign(window, { Icon, Icons, Btn, Card, Hairline, Meta, Pill, Avatar, Placeholder, Rings });
