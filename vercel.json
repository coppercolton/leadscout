// Shared primitives: buttons, cards, badges, icons, placeholders.
// Keep SVGs simple (circles/rects/lines only, per guidance).

const { useState, useEffect, useRef, useMemo } = React;

// ---------- minimal iconography (line weight 1.5) ----------
const Icon = ({ d, size = 16, stroke = 'currentColor', fill = 'none', sw = 1.5, children }) => (
  <svg width={size} height={size} viewBox="0 0 24 24" fill={fill} stroke={stroke}
       strokeWidth={sw} strokeLinecap="round" strokeLinejoin="round" style={{ flexShrink: 0 }}>
    {d ? <path d={d} /> : children}
  </svg>
);

